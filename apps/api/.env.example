# Veriti Voice API — environment variables
# Copy to .env and fill in values

# Allowed CORS origins (comma-separated, include your Vercel URL)
VERITI_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Public base URL for webhook construction
VERITI_PUBLIC_BASE_URL=https://your-api.railway.app

# Environment
VERITI_ENV=production

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-live-preview

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+61xxxxxxxxxx

# Cliniko (set mode=live and provide key for real bookings)
VERITI_CLINIKO_MODE=stub
CLINIKO_API_KEY=
CLINIKO_SHARD=ap1
